# ============================================================
# Sanity — copie ce fichier en ".env.local" et remplis les valeurs
# Tu obtiens le projectId sur https://www.sanity.io/manage
# (ou via "npx sanity init" — voir README)
# ============================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-09-01

# Tant que ces valeurs sont vides, le site s'affiche avec le
# contenu de démonstration (src/lib/fallback.ts).
